# Vercel Serverless / Firebase Admin SDK only. Never expose these in frontend code.
FIREBASE_PROJECT_ID=fifavivacup
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@fifavivacup.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
INVITE_TOKEN_PEPPER=change-me-to-a-long-random-secret

# Optional: force invite URL base in Vercel previews/custom domains.
PUBLIC_APP_URL=https://your-domain.vercel.app
