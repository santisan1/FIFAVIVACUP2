rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // MVP para juntadas: la app usa passcode local en frontend, Firestore no puede validar ese passcode.
    // Para producción pública, reemplazar estas reglas por Auth/Custom Claims de admin.
    match /players/{id} { allow read, write: if true; }
    match /tournaments/{id} { allow read, write: if true; }
    match /tournamentPlayers/{id} { allow read, write: if true; }
    match /matches/{id} { allow read, write: if true; }
    match /goals/{id} { allow read, write: if true; }
    match /feedEvents/{id} { allow read, write: if true; }
    match /tournamentResults/{id} { allow read, write: if true; }
    match /seasonPointEvents/{id} { allow read, write: if true; }

    // Legacy no usado por el flujo JS actual (sin Firebase Auth ni invites serverless).
    match /users/{id} { allow read, write: if false; }
    match /participants/{id} { allow read, write: if false; }
    match /invites/{id} { allow read, write: if false; }
    match /badges/{id} { allow read, write: if false; }
    match /resultProposals/{id} { allow read, write: if false; }
  }
}
